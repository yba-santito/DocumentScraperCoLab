    {full_text[:4000]} # Limiting context window for safety
    """

    payload = {
        "model": "meta-llama/llama-3.3-70b-instruct:free",
        "messages": [{"role": "user", "content": prompt}],
        "temperature": 0.0
    }

    response = requests.post("https://openrouter.ai/api/v1/chat/completions", headers=headers, json=payload)

    tampered = False
    try:
        raw_content = response.json()['choices'][0]['message']['content']
        # Clean up any potential markdown wrappers the LLM might stubbornly add
        clean_json = raw_content.replace("```json", "").replace("```", "").strip()
        transactions = json.loads(clean_json)

        print("\n=== MATH VERIFICATION REPORT ===")

        for i in range(1, len(transactions)):
            prev_balance = float(transactions[i-1]['balance'])
            credit = float(transactions[i]['credit'])
            debit = float(transactions[i]['debit'])
            stated_balance = float(transactions[i]['balance'])

            # Calculate what the balance SHOULD be
            expected_balance = round(prev_balance + credit - debit, 2)

            if expected_balance != stated_balance:
                print(f"🚨 MATH ERROR DETECTED at transaction: '{transactions[i]['description']}'")
                print(f"   Expected Balance: {expected_balance} | Stated Balance: {stated_balance}")
                tampered = True

        if not tampered:
            print("✅ All transaction running balances are mathematically correct.")
        print("==============================\n")

    except Exception as e:
        print(f"❌ Could not parse transactions for math check. Error: {e}")
        tampered = True # Mark as tampered if parsing fails
    return tampered

def verify_bank_statement(pdf_path: str, api_key: str, query_engine):
    print("\n" + "="*50)
    print("🛡️ INITIATING COMPREHENSIVE FICA & FRAUD VERIFICATION 🛡️")
    print("="*50)

    score = 100
    verification_report = []

    # --- STEP 1: RAG FICA Policy Check ---
    print("\n[1/3] Running RAG Policy Guidelines Check...")
    rag_query = (
        "Analyze this bank statement based on the strict verification guidelines. "
        "1. Is the document date within the last 3 months? "
        "2. Are the account holder's name and address present? "
        "3. Is the bank logo and branch code present? "
        "Answer Yes/No for each and briefly explain."
    )
    rag_response = query_engine.run(rag_query)
    print(f"RAG Engine Output:\n{rag_response}")

    # Basic keyword check on RAG response for scoring (can be made more robust)
    if "no" in str(rag_response).lower() or "missing" in str(rag_response).lower():
        score -= 30
        verification_report.append("⚠️ RAG Check: Missing required FICA fields or document is too old.")
    else:
        verification_report.append("✅ RAG Check: Passed FICA requirements.")

    # --- STEP 2: Vision Tampering Check ---
    print("\n[2/3] Running Vision Tampering Detection...")
    vision_result = detect_visual_tampering(pdf_path, api_key)

    if "anomaly" in vision_result.lower() or "mismatch" in vision_result.lower() or "pixelation" in vision_result.lower() or "tampering" in vision_result.lower():
        score -= 40
        verification_report.append("🚨 Vision Check: Possible physical document tampering detected.")
    else:
        verification_report.append("✅ Vision Check: No obvious visual anomalies detected.")

    # --- STEP 3: Mathematical Verification ---
    print("\n[3/3] Running Transaction Math Verification...")
    math_tampered = extract_and_verify_math(pdf_path, api_key)

    if math_tampered:
        score -= 50
        verification_report.append("🚨 Math Check: Running balances do not add up. High probability of forgery.")
    else:
        verification_report.append("✅ Math Check: Running balances are mathematically sound.")

    # --- FINAL DECISION ---
    print("\n" + "="*50)
    print(f"📊 FINAL TRUST SCORE: {score}/100")
    print("="*50)
    for item in verification_report:
        print(item)

    if score >= 80:
        print("\n🟢 DECISION: APPROVED (Low Risk)")
    elif score >= 50:
        print("\n🟡 DECISION: MANUAL REVIEW REQUIRED (Medium Risk)")
    else:
        print("\n🔴 DECISION: REJECTED (High Fraud Risk)")

